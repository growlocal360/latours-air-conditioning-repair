---

<BaseLayout
  title="Reviews & Testimonials | Latour's HVAC - Lake Charles, LA"
  description="Read customer reviews for Latour's HVAC in Lake Charles, LA. See why our customers trust us for AC repair, heating service, and HVAC installation throughout Southwest Louisiana."
  keywords="latours hvac reviews, lake charles ac repair reviews, hvac company reviews lake charles, air conditioning reviews sulphur la"
  ogTitle="Customer Reviews | Latour's HVAC - Lake Charles, LA"
  ogDescription="See what our customers say about Latour's HVAC. 5-star rated AC repair and heating service in Lake Charles and Southwest Louisiana."
  canonicalUrl="https://latourshvac.com/reviews/"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="container">
      <ol>
        <li><a href="/">Home</a></li>
        <li>Reviews</li>
      </ol>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Customer Reviews</h1>
      <p>See what Lake Charles and Southwest Louisiana homeowners say about Latour's HVAC service.</p>
    </div>
  </section>

  <!-- Rating Summary -->
  <section class="content-section" style="padding-bottom: 0;">
    <div class="container">
      <div style="background: var(--off-white); padding: 2rem; border-radius: var(--radius-lg); text-align: center; max-width: 600px; margin: 0 auto;">
        <div style="font-size: 3rem; font-weight: 700; color: var(--primary-blue);">5.0</div>
        <div style="color: #f5a623; font-size: 1.5rem; margin: 0.5rem 0;">
          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
        </div>
        <p style="margin: 0; color: var(--medium-gray);">Based on 170+ customer reviews on Google</p>
        <div style="margin-top: 1rem; display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
          <a href="https://www.google.com/search?q=latours+hvac+lake+charles" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">Google Reviews</a>
          <a href="https://www.facebook.com/latoursac" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">Facebook Reviews</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Grid -->
  <section class="content-section">
    <div class="container">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
        {reviews.map((review) => (
          <div style="background: #fff; border: 1px solid var(--light-gray); border-radius: var(--radius-lg); padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <div>
                <div style="font-weight: 600; color: var(--dark-gray);">{review.name}</div>
                <div style="font-size: 0.875rem; color: var(--medium-gray);">{review.location}</div>
              </div>
              <div style="color: #f5a623;">
                {Array(review.rating).fill('').map(() => <span>&#9733;</span>)}
              </div>
            </div>
            <div style="font-size: 0.75rem; color: var(--primary-blue); font-weight: 500; margin-bottom: 0.75rem; text-transform: uppercase;">
              {review.service} &bull; {review.date}
            </div>
            <p style="margin: 0; color: var(--dark-gray); line-height: 1.6;">"{review.text}"</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Leave Review CTA -->
  <section style="background: var(--off-white); padding: 3rem 0;">
    <div class="container" style="text-align: center;">
      <h2>Had a Great Experience?</h2>
      <p style="max-width: 600px; margin: 0 auto 1.5rem;">We'd love to hear from you! Your feedback helps us improve and helps other homeowners find reliable HVAC service.</p>
      <a href="https://www.google.com/search?q=latours+hvac+lake+charles" target="_blank" rel="noopener" class="btn btn-primary btn-lg">Leave a Google Review</a>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <h2>Experience the Latour's Difference</h2>
      <p>Join our family of satisfied customers across Southwest Louisiana.</p>
      <div class="cta-phone">
        <a href="tel:+13375134425">(337) 513-4425</a>
      </div>
      <div class="cta-buttons">
        <a href="tel:+13375134425" class="btn btn-secondary btn-lg">Call Now</a>
        <a href="/schedule-service/" class="btn btn-outline-white btn-lg">Schedule Online</a>
      </div>
    </div>
  </section>
</BaseLayout>
