---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSnapBySlug } from '../../lib/jobsnaps/queries';

export const prerender = false;

const { slug } = Astro.params;
const snap = slug ? await getSnapBySlug(slug) : null;

if (!snap) {
  return new Response('Not Found', {
    status: 404,
    headers: { 'content-type': 'text/plain' },
  });
}

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=600',
);

const featured = snap.media?.[0];
const gallery = snap.media ?? [];
const loc = snap.location ?? null;

function locationLabel(): string {
  if (!loc) return '';
  const parts = [loc.address, loc.city, loc.state, loc.zip].filter(Boolean);
  return parts.join(', ');
}

const canonicalUrl = `https://latourshvac.com/work/${snap.slug}`;
const pageTitle = `${snap.title || 'Recent HVAC Job'} | Latour's Air Conditioning & Heating`;
const pageDescription =
  (snap.description && snap.description.slice(0, 160)) ||
  `Recent HVAC job by Latour's Air Conditioning & Heating in Lake Charles, LA.`;
const ogImage = featured?.url;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: snap.title || 'Recent HVAC Job',
  description: snap.description || pageDescription,
  image: gallery.map((m) => m.url).filter(Boolean),
  datePublished: snap.published_at,
  dateModified: snap.updated_at,
  author: {
    '@type': 'Organization',
    name: "Latour's Air Conditioning & Heating, LLC",
    url: 'https://latourshvac.com',
  },
  publisher: {
    '@type': 'Organization',
    name: "Latour's Air Conditioning & Heating, LLC",
    url: 'https://latourshvac.com',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(loc && (loc.address || loc.city)
    ? {
        contentLocation: {
          '@type': 'Place',
          address: {
            '@type': 'PostalAddress',
            streetAddress: loc.address ?? undefined,
            addressLocality: loc.city ?? undefined,
            addressRegion: loc.state ?? undefined,
            postalCode: loc.zip ?? undefined,
            addressCountry: 'US',
          },
        },
      }
    : {}),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogTitle={snap.title ?? pageTitle}
  ogDescription={pageDescription}
  ogImage={ogImage}
  schema={articleSchema}
>
  <main class="snap">
    <article>
      <header class="snap__header">
        <p class="snap__crumb"><a href="/work">← Recent Work</a></p>
        <h1>{snap.title || 'Recent HVAC Job'}</h1>
        <ul class="snap__meta">
          {snap.service_type && <li><strong>Service:</strong> {snap.service_type}</li>}
          {snap.brand && <li><strong>Brand:</strong> {snap.brand}</li>}
          {locationLabel() && <li><strong>Location:</strong> {locationLabel()}</li>}
        </ul>
      </header>

      {snap.description && (
        <section class="snap__body">
          {snap.description.split('\n\n').map((para) => <p>{para}</p>)}
        </section>
      )}

      {gallery.length > 0 && (
        <section class="snap__gallery" aria-label="Photos from this job">
          {gallery.map((m) => (
            <figure>
              <img
                src={m.url}
                alt={m.alt || snap.title || 'HVAC job photo'}
                width={m.width ?? undefined}
                height={m.height ?? undefined}
                loading="lazy"
              />
              {m.alt && <figcaption>{m.alt}</figcaption>}
            </figure>
          ))}
        </section>
      )}
    </article>
  </main>
</BaseLayout>

<style>
  .snap {
    max-width: 920px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
  }
  .snap__header { margin-bottom: 1.5rem; }
  .snap__crumb a {
    color: #555;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .snap__crumb a:hover { text-decoration: underline; }
  .snap__header h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin: 0.5rem 0 0.75rem;
    line-height: 1.2;
  }
  .snap__meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    color: #555;
    font-size: 0.95rem;
  }
  .snap__meta li strong { color: #222; margin-right: 0.25rem; }
  .snap__body {
    margin: 1.5rem 0 2rem;
    line-height: 1.65;
    color: #333;
  }
  .snap__body p { margin: 0 0 1rem; }
  .snap__gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 0;
  }
  @media (min-width: 720px) {
    .snap__gallery { grid-template-columns: repeat(2, 1fr); }
  }
  .snap__gallery figure {
    margin: 0;
    background: #f4f4f4;
    border-radius: 8px;
    overflow: hidden;
  }
  .snap__gallery img {
    width: 100%;
    height: auto;
    display: block;
  }
  .snap__gallery figcaption {
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    color: #666;
  }
</style>
