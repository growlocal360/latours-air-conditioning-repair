# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- HighLevel (GoHighLevel) ---
# v2 Private Integration Token. Create at: Settings -> Private Integrations.
# Required scopes: socialplanner/post.write, socialplanner/post.readonly,
# socialplanner/account.readonly, medias.write, locations.readonly
GHL_PIT=
# Sub-account / Location ID. Find at Settings -> Business Profile, or in
# the URL: app.gohighlevel.com/v2/location/{LOCATION_ID}/...
GHL_LOCATION_ID=
GHL_API_VERSION=2021-07-28

# --- Google Analytics 4 ---
# Numeric Property ID (e.g. 123456789). For the Data API.
GA_PROPERTY_ID=

# --- Google Search Console ---
# Verified site URL. Use exactly the form Search Console shows it
# (e.g. "sc-domain:latourshvac.com" or "https://www.latourshvac.com/")
GSC_SITE_URL=

# --- Google Cloud service account ---
# Absolute path to the service account JSON key file (kept OUT of the repo).
# Recommended location: ~/.config/latours-hvac/ga-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Supabase (used by Job Snaps integration) ---
# Project URL, e.g. https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Anon (public) key — safe for read-only client/SSR access bounded by RLS.
SUPABASE_ANON_KEY=
# Service role key — server-only writes. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Job Snaps (GrowLocal 360) ---
# Outbound API key (only needed if we ever call Job Snaps' API directly).
JOBSNAPS_API_KEY=
# Inbound webhook signing secret. Used to verify X-Webhook-Signature on
# POSTs from Job Snaps to /api/jobsnaps-webhook.
JOBSNAPS_WEBHOOK_SECRET=
# Job Snaps admin/API base URL.
JOBSNAPS_API_BASE=https://admin.goleadflow.com
